# Notion CMS Configuration
VITE_NOTION_TOKEN=tu_token_notion_aqui
VITE_NOTION_DATABASE_ID=tu_database_id_notion_aqui

# EmailJS Configuration (para formularios de contacto)
# Obtener en: https://www.emailjs.com/
# 1. Crear cuenta
# 2. Crear servicio de email (Gmail, etc.)
# 3. Crear 2 templates (Personas y Entidades)
# 4. Copiar Public Key desde Account > General
VITE_EMAILJS_SERVICE_ID=service_tu_id_aqui
VITE_EMAILJS_TEMPLATE_ID_PERSONAS=template_personas_aqui
VITE_EMAILJS_TEMPLATE_ID_ENTIDADES=template_entidades_aqui
VITE_EMAILJS_USER_ID=tu_public_key_aqui

# Google Analytics 4 Configuration
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
