        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "El Real Decreto 316/2026 no surgió de un despacho ministerial. Surgió de más de 700.000 firmas. De personas que dijeron basta a la invisibilidad.",
                "link": null
              },
              "annotations": {
