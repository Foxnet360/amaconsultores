        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "La cooperación ordenada, libre y regular no es un ideal abstracto. Es la única respuesta estructural que conocemos. Es en lo que creo, y es por lo que trabajo.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "La cooperación ordenada, libre y regular no es un ideal abstracto. Es la única respuesta estructural que conocemos. Es en lo que creo, y es por lo que trabajo.",
              "href": null
            }
          ],
          "icon": null,
          "color": "default"
